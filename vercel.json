{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/sync-permits",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-permit-stages",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/canary",
      "schedule": "*/15 * * * *"
    }
  ]
}
